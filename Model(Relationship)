class Notaire extends Model {
    protected $primaryKey = 'numn';
    public $incrementing = false;

    public function dossiers() {
        return $this->hasMany(Dossier_Terrain::class, 'numnotaire', 'numn');
    }
}

secend table :
class Dossier_Terrain extends Model {
    protected $primaryKey = 'iddossier';
    public $incrementing = false;

    public function notaire() {
        return $this->belongsTo(Notaire::class, 'numnotaire', 'numn');
    }
}


